<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title> AI TaskOrbit  – Never Miss a Customer Call Again</title>
  <meta name="description" content="AI TaskOrbit  Voice Agent answers, qualifies, and converts customer calls 24/7 so you save time, cut costs, and capture more revenue." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      /* parallax rotation values controlled by JS */
      --scene-rotate-x: -6deg;
      --scene-rotate-y: 6deg;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #020617;
      color: #e5e7eb;
      line-height: 1.6;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }

    /* Animated gradient background layer */
    body::before {
      content: "";
      position: fixed;
      inset: -40%;
      z-index: -1;
      background: radial-gradient(circle at 0% 0%, #22c55e 0, transparent 45%),
                  radial-gradient(circle at 100% 0%, #0ea5e9 0, transparent 45%),
                  radial-gradient(circle at 0% 100%, #6366f1 0, transparent 45%),
                  radial-gradient(circle at 100% 100%, #f97316 0, transparent 45%);
      opacity: 0.65;
      filter: blur(40px);
      transform: translate3d(0, 0, 0);
      animation: bg-orbit 26s ease-in-out infinite alternate;
    }

    @keyframes bg-orbit {
      0% {
        transform: translate3d(-40px, -20px, 0) scale(1);
        opacity: 0.6;
      }
      50% {
        transform: translate3d(40px, 40px, 0) scale(1.05);
        opacity: 0.9;
      }
      100% {
        transform: translate3d(-20px, 60px, 0) scale(1.02);
        opacity: 0.7;
      }
    }

    /* Layout */

    .container {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }

    .section-title.center {
      text-align: center;
    }

    .section-subtitle {
      color: #9ca3af;
      max-width: 40rem;
      margin-bottom: 2rem;
    }

    .section-subtitle.center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    /* Header */

    .site-header {
      position: sticky;
      top: 0;
      z-index: 30;
      backdrop-filter: blur(18px);
      background: linear-gradient(to right, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.88));
      border-bottom: 1px solid rgba(148, 163, 184, 0.28);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 0;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      color: inherit;
    }

    /* Animated logo similar feel to meetsansara */
    .logo-mark {
      width: 36px;
      height: 36px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 30% 20%, #f9fafb 0, #e5e7eb 24%, transparent 55%),
        conic-gradient(from 210deg, #0ea5e9, #38bdf8, #6366f1, #22c55e, #0ea5e9);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(15, 23, 42, 0.9),
        0 14px 35px rgba(15, 23, 42, 0.9),
        0 0 25px rgba(56, 189, 248, 0.7);
      animation: logo-ring 10s linear infinite;
    }

    .logo-mark::before {
      content: "";
      position: absolute;
      inset: 18%;
      border-radius: inherit;
      background: radial-gradient(circle at 30% 20%, #0f172a 0, #020617 55%);
      box-shadow: inset 0 0 18px rgba(15, 23, 42, 0.9);
    }

    .logo-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #e0f2fe;
      box-shadow: 0 0 16px rgba(125, 211, 252, 0.9);
      animation: logo-pulse 2.4s ease-in-out infinite;
      position: relative;
      z-index: 1;
    }

    @keyframes logo-ring {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes logo-pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.25); opacity: 0.75; }
    }

    .logo-text {
      display: flex;
      flex-direction: column;
    }

    .logo-title {
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    .logo-sub {
      font-size: 0.75rem;
      color: #9ca3af;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .nav-link {
      background: none;
      border: none;
      color: #e5e7eb;
      font-size: 0.88rem;
      padding: 0.5rem 0.75rem;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
    }

    .nav-link:hover {
      background: rgba(148, 163, 184, 0.18);
      transform: translateY(-1px);
    }

    .nav-link-pill {
      border: 1px solid rgba(56, 189, 248, 0.7);
      color: #bae6fd;
    }

    .btn {
      border-radius: 999px;
      border: none;
      padding: 0.65rem 1.3rem;
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      background: linear-gradient(135deg, #0ea5e9, #6366f1);
      color: #f9fafb;
      box-shadow:
        0 18px 50px rgba(37, 99, 235, 0.45),
        0 0 0 1px rgba(15, 23, 42, 0.9);
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease,
        background 0.18s ease;
    }

    .btn:hover {
      transform: translateY(-2px) translateZ(5px);
      box-shadow:
        0 28px 70px rgba(37, 99, 235, 0.65),
        0 0 0 1px rgba(56, 189, 248, 0.7);
    }

    .btn-outline {
      background: transparent;
      color: #e5e7eb;
      border: 1px solid rgba(148, 163, 184, 0.7);
      box-shadow: none;
    }

    .btn-outline:hover {
      background: rgba(15, 23, 42, 0.9);
      border-color: rgba(56, 189, 248, 0.8);
    }

    .btn-sm {
      padding: 0.45rem 0.9rem;
      font-size: 0.8rem;
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 0.2rem;
      background: none;
      border: none;
      cursor: pointer;
    }

    .nav-toggle span {
      width: 18px;
      height: 2px;
      border-radius: 999px;
      background: #e5e7eb;
    }

    /* Parallax root – 3D tilt for whole hero area */
    .parallax-root {
      perspective: 1200px;
      perspective-origin: 50% 40%;
    }

    .parallax-scene {
      transform-style: preserve-3d;
      transform: rotateX(var(--scene-rotate-x)) rotateY(var(--scene-rotate-y));
      transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1);
    }

    /* Hero */

    .hero {
      padding-top: 4.5rem;
      padding-bottom: 4.5rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1.1fr);
      gap: 2.5rem;
      align-items: center;
    }

    .eyebrow {
      font-size: 0.85rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 0.75rem;
    }

    .hero-title {
      font-size: 2.9rem;
      line-height: 1.1;
      font-weight: 800;
      margin-bottom: 1rem;
      background: linear-gradient(130deg, #f9fafb, #e5e7eb, #bfdbfe);
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero-subtitle {
      color: #e5e7f5;
      margin-bottom: 1.5rem;
    }

    .hero-bullets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .hero-bullet {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid rgba(148, 163, 184, 0.4);
      font-size: 0.9rem;
    }

    .bullet-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 10px rgba(34, 197, 94, 0.7);
    }

    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .hero-footnote {
      font-size: 0.9rem;
      color: #94a3b8;
    }

    .hero-panel {
      background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.27), transparent 55%),
        radial-gradient(circle at bottom right, rgba(79, 70, 229, 0.24), transparent 60%),
        rgba(15, 23, 42, 0.98);
      border-radius: 1.5rem;
      padding: 1.8rem 1.6rem;
      border: 1px solid rgba(148, 163, 184, 0.6);
      position: relative;
      overflow: hidden;
      box-shadow:
        0 25px 60px rgba(15, 23, 42, 0.9),
        0 0 0 1px rgba(15, 23, 42, 1);
      transform-style: preserve-3d;
    }

    .hero-panel::after {
      content: "";
      position: absolute;
      inset: -40%;
      background: radial-gradient(circle at 20% 0%, rgba(251, 191, 36, 0.15), transparent 55%);
      opacity: 0.7;
      mix-blend-mode: screen;
      pointer-events: none;
    }

    .hero-metric-row {
      display: flex;
      justify-content: space-between;
      gap: 1.25rem;
      margin-bottom: 1.35rem;
      transform: translateZ(30px);
    }

    .metric-label {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: #94a3b8;
    }

    .metric-main {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 0.2rem;
      margin-bottom: 0.3rem;
    }

    .metric-sub {
      font-size: 0.85rem;
      color: #9ca3af;
    }

    .hero-mini .mini-label {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: #a5b4fc;
      margin-bottom: 0.35rem;
    }

    .hero-mini ul {
      list-style: none;
      font-size: 0.85rem;
      color: #e5e7eb;
    }

    .hero-mini li + li {
      margin-top: 0.25rem;
    }

    .hero-math {
      border-radius: 1.1rem;
      padding: 1rem 1.1rem;
      background: rgba(15, 23, 42, 0.96);
      border: 1px dashed rgba(148, 163, 184, 0.65);
      transform: translateZ(18px);
    }

    .math-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.9rem;
      color: #e5e7eb;
    }

    .math-row + .math-row {
      margin-top: 0.25rem;
    }

    .math-row-strong {
      margin-top: 0.5rem;
      font-weight: 600;
    }

    .math-note {
      font-size: 0.78rem;
      color: #9ca3af;
      margin-top: 0.6rem;
    }

    .section-split .split-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.1fr);
      gap: 2.5rem;
      align-items: start;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.7);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #9ca3af;
      margin-bottom: 0.9rem;
    }

    .pill-danger {
      border-color: rgba(248, 113, 113, 0.8);
      color: #fecaca;
    }

    .list {
      list-style: none;
      color: #d1d5db;
      font-size: 0.95rem;
    }

    .list li + li {
      margin-top: 0.5rem;
    }

    .list-icon li::before {
      content: "•";
      color: #38bdf8;
      margin-right: 0.4rem;
    }

    .list-success li::before {
      color: #22c55e;
    }

    .inline-highlight {
      margin-top: 1.1rem;
      font-size: 0.9rem;
      color: #a5b4fc;
    }

    .grid {
      display: grid;
      gap: 1.5rem;
    }

    .grid-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .grid-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .card {
      background: rgba(15, 23, 42, 0.98);
      border-radius: 1.1rem;
      border: 1px solid rgba(30, 64, 175, 0.55);
      padding: 1.3rem 1.3rem;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.75);
      transform-style: preserve-3d;
    }

    .roi-icon {
      font-size: 1.6rem;
      margin-bottom: 0.4rem;
    }

    .card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .card p {
      font-size: 0.9rem;
      color: #d1d5db;
    }

    .pricing-card {
      position: relative;
    }

    .pricing-card-featured {
      border-color: rgba(56, 189, 248, 0.9);
      box-shadow:
        0 24px 70px rgba(37, 99, 235, 0.55),
        0 0 0 1px rgba(37, 99, 235, 0.8);
    }

    .plan-badge {
      position: absolute;
      top: 0.9rem;
      left: 50%;
      transform: translateX(-50%);
      padding: 0.25rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(56, 189, 248, 0.9);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      background: rgba(15, 23, 42, 0.98);
      color: #ccfbf1;
    }

    .plan-name {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #9ca3af;
      margin-bottom: 0.35rem;
      padding-top: 1.4rem;
    }

    .plan-price {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
    }

    .plan-price span {
      font-size: 0.8rem;
      font-weight: 400;
      color: #9ca3af;
    }

    .plan-tagline {
      font-size: 0.9rem;
      color: #d1d5db;
      margin-bottom: 0.75rem;
    }

    .plan-list {
      list-style: none;
      font-size: 0.86rem;
      color: #d1d5db;
      margin-bottom: 0.9rem;
    }

    .plan-list li + li {
      margin-top: 0.3rem;
    }

    .plan-cta {
      width: 100%;
    }

    .testimonial-card .quote {
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .testimonial-card .author {
      font-size: 0.8rem;
      color: #9ca3af;
    }

    .contact-highlights {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .contact-pill {
      font-size: 0.8rem;
      padding: 0.25rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.6);
    }

    .contact-meta p {
      font-size: 0.9rem;
      color: #d1d5db;
    }

    .contact-meta a {
      color: #7dd3fc;
      text-decoration: none;
    }

    .contact-meta a:hover {
      text-decoration: underline;
    }

    .form-card {
      padding: 1.4rem 1.4rem;
    }

    .form-title {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem 1rem;
      margin-bottom: 0.9rem;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .form-field label {
      font-size: 0.8rem;
      color: #9ca3af;
    }

    .form-field input,
    .form-field textarea {
      border-radius: 0.7rem;
      border: 1px solid rgba(148, 163, 184, 0.6);
      background: rgba(15, 23, 42, 0.98);
      padding: 0.55rem 0.7rem;
      font-size: 0.9rem;
      color: #e5e7eb;
    }

    .form-field input:focus,
    .form-field textarea:focus {
      outline: none;
      border-color: #38bdf8;
      box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.7);
    }

    .form-footer {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.5rem;
    }

    .form-status {
      font-size: 0.8rem;
      color: #9ca3af;
    }

    .metric-card .metric-main {
      font-size: 1.3rem;
      font-weight: 600;
    }

    .metric-card .metric-label {
      font-size: 0.85rem;
      color: #9ca3af;
    }

    .metric-card .metric-sub {
      font-size: 0.8rem;
      color: #9ca3af;
    }

    .admin-table-card {
      margin-top: 1.6rem;
    }

    .admin-table-header {
      margin-bottom: 0.8rem;
    }

    .admin-table-sub {
      font-size: 0.85rem;
      color: #9ca3af;
    }

    .table-wrapper {
      overflow-x: auto;
    }

    .table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    .table th,
    .table td {
      border-bottom: 1px solid rgba(148, 163, 184, 0.3);
      padding: 0.5rem 0.7rem;
      text-align: left;
    }

    .table th {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #9ca3af;
    }

    .empty-row td {
      text-align: center;
      color: #6b7280;
      font-style: italic;
    }

    .site-footer {
      padding: 1.5rem 0 2rem;
      border-top: 1px solid rgba(148, 163, 184, 0.35);
      margin-top: 2rem;
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      align-items: center;
      font-size: 0.8rem;
      color: #9ca3af;
    }

    .whatsapp-fab {
      position: fixed;
      right: 1.3rem;
      bottom: 1.3rem;
      width: 46px;
      height: 46px;
      border-radius: 999px;
      background: linear-gradient(135deg, #22c55e, #16a34a);
      color: #f9fafb;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      box-shadow: 0 12px 35px rgba(22, 163, 74, 0.6);
    }

    /* 3D hover on cards */

    .scene-3d {
      perspective: 1100px;
      perspective-origin: 50% 40%;
    }

    .tilt-card {
      transform-style: preserve-3d;
      transition:
        transform 0.3s cubic-bezier(0.19, 1, 0.22, 1),
        box-shadow 0.3s cubic-bezier(0.19, 1, 0.22, 1),
        border-color 0.3s ease;
    }

    .tilt-card .tilt-inner {
      transform: translateZ(22px);
    }

    .tilt-card:hover {
      transform: rotateX(-10deg) rotateY(10deg) translateY(-6px);
      box-shadow:
        0 26px 70px rgba(15, 23, 42, 0.95),
        0 0 0 1px rgba(56, 189, 248, 0.7);
      border-color: rgba(56, 189, 248, 0.85);
    }

    /* Simple fade-up animation */

    @keyframes fade-up {
      from {
        opacity: 0;
        transform: translateY(18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-in {
      opacity: 0;
      transform: translateY(18px);
      animation: fade-up 0.7s ease forwards;
    }

    .animate-delay-1 { animation-delay: 0.15s; }
    .animate-delay-2 { animation-delay: 0.3s; }
    .animate-delay-3 { animation-delay: 0.45s; }

    /* Responsive */

    @media (max-width: 960px) {
      .hero-grid {
        grid-template-columns: minmax(0, 1fr);
      }
      .section-split .split-grid {
        grid-template-columns: minmax(0, 1fr);
      }
      .grid-3 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .grid-4 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .nav {
        display: none;
      }

      .nav.nav-open {
        position: fixed;
        inset: 3.1rem 1rem auto 1rem;
        border-radius: 1rem;
        background: rgba(15, 23, 42, 0.97);
        border: 1px solid rgba(148, 163, 184, 0.45);
        padding: 0.75rem;
        flex-direction: column;
        align-items: flex-start;
      }

      .nav-toggle {
        display: inline-flex;
      }

      .hero {
        padding-top: 3.5rem;
      }

      .grid-3,
      .grid-4 {
        grid-template-columns: minmax(0, 1fr);
      }

      .form-grid {
        grid-template-columns: minmax(0, 1fr);
      }

      .tilt-card {
        transform: none;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="#top" class="logo">
        <div class="logo-mark" aria-hidden="true">
          <span class="logo-dot"></span>
        </div>
        <div class="logo-text">
          <span class="logo-title">AI TaskOrbit</span>
          <span class="logo-sub">AI Voice Agent Platform</span>
        </div>
      </a>
