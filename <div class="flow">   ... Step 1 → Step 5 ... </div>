    box-shadow 0.3s cubic-bezier(0.19, 1, 0.22, 1),
    border-color 0.3s ease;
}

.flow-step-card p {
  font-size: 0.9rem;
  color: #e5e7eb;
}

.flow-step-tag {
  display: inline-flex;
