.flow-step-3d {
  display: grid;
  grid-template-columns: auto 1fr;
  column-gap: 0.8rem;
  align-items: center;
  position: relative;
  transform-style: preserve-3d;
}

.flow-step-card {
  background: rgba(15, 23, 42, 0.98);
