  <script>
    // Smooth scroll for nav buttons
    (function () {
      const scrollButtons = document.querySelectorAll("[data-scroll]");
      scrollButtons.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = btn.getAttribute("data-scroll");
          if (!target) return;
          const el = document.querySelector(target);
          if (!el) return;
          e.preventDefault();
          el.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });
    })();

    // Mobile nav toggle
    (function () {
      const toggle = document.querySelector(".nav-toggle");
      const nav = document.querySelector(".nav");
      if (!toggle || !nav) return;
      toggle.addEventListener("click", () => {
        nav.classList.toggle("nav-open");
        toggle.classList.toggle("nav-open");
      });
    })();

    // Footer year
    (function () {
      const yearEl = document.getElementById("year");
      if (yearEl) {
        yearEl.textContent = new Date().getFullYear();
      }
    })();

    // Live revenue estimate (static calc)
    (function () {
      const liveEl = document.getElementById("liveRevenue");
      if (!liveEl) return;
      const MISSED_CALLS_PER_DAY = 5;
      const VALUE_PER_CUSTOMER = 1000;
      const DAYS_PER_MONTH = 30;
      const lost = MISSED_CALLS_PER_DAY * VALUE_PER_CUSTOMER * DAYS_PER_MONTH;
      const formatter = new Intl.NumberFormat("en-IN", {
        style: "currency",
        currency: "INR",
        maximumFractionDigits: 0
      });
      liveEl.textContent = formatter.format(lost);
    })();

    // Enquiry form → demo admin dashboard
    (function () {
      const form = document.getElementById("enquiryForm");
      if (!form) return;

      const statusEl = document.getElementById("enquiryStatus");
      const totalLeadsEl = document.getElementById("totalLeads");
      const todayLeadsEl = document.getElementById("todayLeads");
      const topBusinessTypeEl = document.getElementById("topBusinessType");
      const tableBody = document.getElementById("leadTableBody");

      const leads = [];

      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const name = (formData.get("name") || "").toString().trim() || "Unknown";
        const email = (formData.get("email") || "").toString().trim();
        const phone = (formData.get("phone") || "").toString().trim();
        const businessType = (formData.get("businessType") || "").toString().trim() || "Other";
        const message = (formData.get("message") || "").toString().trim();

        const lead = {
          name,
          email,
          phone,
          businessType,
          message,
          status: "New",
          createdAt: new Date()
        };

        leads.unshift(lead);

        const total = leads.length;
        if (totalLeadsEl) totalLeadsEl.textContent = total.toString();

        const today = new Date().toDateString();
        const todayCount = leads.filter((l) => l.createdAt.toDateString() === today).length;
        if (todayLeadsEl) todayLeadsEl.textContent = todayCount.toString();

        const byType = leads.reduce((acc, l) => {
          acc[l.businessType] = (acc[l.businessType] || 0) + 1;
          return acc;
        }, {});
        const topType = Object.entries(byType).sort((a, b) => b[1] - a[1])[0]?.[0] || "—";
        if (topBusinessTypeEl) topBusinessTypeEl.textContent = topType;

        if (tableBody) {
          tableBody.innerHTML = "";
          leads.forEach((l) => {
            const tr = document.createElement("tr");
            const created = l.createdAt.toLocaleString();
            tr.innerHTML = `
              <td>${l.name}</td>
              <td>${l.businessType}</td>
              <td>${l.phone}</td>
              <td>${l.status}</td>
              <td>${created}</td>
            `;
            tableBody.appendChild(tr);
          });
        }

        if (statusEl) {
          statusEl.textContent = "Thanks! We’ll share your demo and ROI breakdown shortly.";
        }

        form.reset();
      });
    })();

    // Global parallax rotation (mouse-based 3D motion)
    (function () {
      const scene = document.querySelector(".parallax-scene");
      if (!scene) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const finePointer = window.matchMedia("(pointer: fine)").matches;
      if (prefersReduced || !finePointer) return;

      const root = document.documentElement;
      let targetX = -6;
      let targetY = 6;
      let currentX = targetX;
      let currentY = targetY;
      let rafId = null;

      function animate() {
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;
        root.style.setProperty("--scene-rotate-x", currentX + "deg");
        root.style.setProperty("--scene-rotate-y", currentY + "deg");
        rafId = requestAnimationFrame(animate);
      }

      function handleMove(e) {
        const xRatio = (e.clientX / window.innerWidth) - 0.5;
        const yRatio = (e.clientY / window.innerHeight) - 0.5;
        const maxTilt = 10;
        targetY = xRatio * maxTilt * -1; // rotateY
        targetX = yRatio * maxTilt;      // rotateX
        if (!rafId) rafId = requestAnimationFrame(animate);
      }

      window.addEventListener("mousemove", handleMove);
    })();
  </script>
